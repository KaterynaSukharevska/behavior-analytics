// Behavior Analytics MVP — raw event storage (Phase 3.1 foundation)
// Persist validated events in Phase 3.2; this schema only defines the table.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// One row per ingested analytics event. `payload` holds the full validated event JSON.
model RawEvent {
  id         String   @id @default(uuid())
  site_id    String
  session_id String
  event_id   String
  event_type String
  timestamp  DateTime
  payload    Json
  created_at DateTime @default(now())

  @@index([site_id])
  @@index([session_id])
  @@index([event_type])
  @@map("raw_events")
}
