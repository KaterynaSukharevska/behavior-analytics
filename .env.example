# Copy this file to `.env` in the project root before running Prisma or the ingest API.
# Prisma reads DATABASE_URL from the project root (prisma/schema.prisma).
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/behavior_analytics
DASHBOARD_PORT=3000
DEMO_SITE_PORT=3001
INGEST_API_PORT=4000
POSTGRES_DB=behavior_analytics
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432
